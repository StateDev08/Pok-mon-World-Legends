<IfModule mod_rewrite.c>
    RewriteEngine On

    # Do not expose .env or install.lock files through the web server
    RewriteRule \.(env|lock)$ - [F,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    RewriteRule ^([^\.]*)$ index.php?page=$1 [L]
</IfModule>

Options -Indexes

# Additional protection for .env files
<FilesMatch "\.env$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
